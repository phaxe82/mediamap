---
const steps = [
  {
    number: '01',
    title: 'Tell us what you make',
    description:
      'Share your workflow, your tools, and your pain points. Every creator is different — we start by understanding yours.',
  },
  {
    number: '02',
    title: 'We map the landscape',
    description:
      "We assess the AI tools relevant to your specific role and workflow — cutting through the hype to find what's actually useful.",
  },
  {
    number: '03',
    title: 'Get back to creating',
    description:
      'Leave with a clear, practical plan. Less time googling AI tools. More time making the work you love.',
  },
];
---

<section id="how-it-works" class="py-24 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl mb-16">
      <p class="text-[#f5a623] text-sm font-semibold uppercase tracking-widest mb-4">
        How It Works
      </p>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight">
        Simple process.<br />
        <span class="text-[#f5a623]">Real results.</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop only) -->
      <div
        class="hidden md:block absolute top-8 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
      >
      </div>

      {
        steps.map((step) => (
          <div class="relative">
            <div class="text-5xl font-black text-[#f5a623]/20 mb-4">{step.number}</div>
            <h3 class="text-xl font-bold mb-3">{step.title}</h3>
            <p class="text-white/50 leading-relaxed">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
