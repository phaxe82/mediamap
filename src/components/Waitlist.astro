---
---

<section id="waitlist" class="py-24 px-6 border-t border-white/5">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-[#f5a623] text-sm font-semibold uppercase tracking-widest mb-6">
      Early Access
    </p>
    <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6">
      The future of media<br />
      <span class="text-[#f5a623]">is being written now.</span>
    </h2>
    <p class="text-white/50 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
      Don't get left behind. Join the waitlist and be first to know when Media Map opens for
      consultations.
    </p>

    <!-- Waitlist form -->
    <form
      class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
      onsubmit="handleSubmit(event)"
      id="waitlist-form"
    >
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 bg-white/[0.05] border border-white/10 text-white placeholder-white/30 px-5 py-4 rounded-full focus:outline-none focus:border-[#f5a623]/50 transition-colors"
      />
      <button
        type="submit"
        class="bg-[#f5a623] text-black font-bold px-6 py-4 rounded-full hover:bg-[#e09415] transition-colors whitespace-nowrap"
      >
        Request Access
      </button>
    </form>

    <!-- Success message (hidden by default) -->
    <p id="success-msg" class="hidden mt-4 text-[#f5a623] font-medium">
      You're on the list. We'll be in touch.
    </p>

    <p class="mt-4 text-white/30 text-sm">No spam. No hard sell. Just useful stuff.</p>
  </div>
</section>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    const form = document.getElementById('waitlist-form') as HTMLFormElement;
    const msg = document.getElementById('success-msg');
    if (form && msg) {
      form.classList.add('hidden');
      msg.classList.remove('hidden');
    }
  }
  // Make accessible globally
  (window as any).handleSubmit = handleSubmit;
</script>
