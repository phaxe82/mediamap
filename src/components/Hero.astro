---
---

<section class="min-h-screen flex items-center justify-center px-6 pt-24 pb-16">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Eyebrow -->
    <p class="text-[#f5a623] text-sm font-semibold uppercase tracking-widest mb-6">
      AI Consulting for Media Creators
    </p>

    <!-- Main headline -->
    <h1 class="text-5xl md:text-7xl font-black leading-[1.05] tracking-tight mb-6">
      Will AI take<br />
      <span class="text-[#f5a623]">my job?</span>
    </h1>
    <h2 class="text-4xl md:text-6xl font-black leading-[1.05] tracking-tight mb-8 text-white/40">
      Maybe.
    </h2>

    <!-- Subheading -->
    <p class="text-lg md:text-xl text-white/60 max-w-2xl mx-auto mb-10 leading-relaxed">
      We help film, TV and media creators figure out which AI tools are actually worth your time —
      so you can stop worrying about the future and get back to creating.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="#waitlist"
        class="bg-[#f5a623] text-black font-bold px-8 py-4 rounded-full text-base hover:bg-[#e09415] transition-colors w-full sm:w-auto"
      >
        Request Early Access
      </a>
      <a
        href="#how-it-works"
        class="text-white/60 font-medium px-8 py-4 rounded-full text-base border border-white/10 hover:border-white/30 hover:text-white transition-colors w-full sm:w-auto"
      >
        See How It Works
      </a>
    </div>

    <!-- Scroll hint -->
    <div class="mt-20 flex justify-center">
      <div class="w-px h-16 bg-gradient-to-b from-white/20 to-transparent"></div>
    </div>
  </div>
</section>
