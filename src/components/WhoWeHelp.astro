---
const creators = [
  'Film Directors',
  'TV Producers',
  'Video Editors',
  'Colourists',
  'VFX Artists',
  'Sound Designers',
  'Composers',
  'Cinematographers',
  'Script Writers',
  'Documentary Makers',
  'Journalists',
  'Content Creators',
];
---

<section class="py-24 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Left: text -->
      <div>
        <p class="text-[#f5a623] text-sm font-semibold uppercase tracking-widest mb-4">
          Who We Help
        </p>
        <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-6">
          If you make media,<br />
          <span class="text-[#f5a623]">this is for you.</span>
        </h2>
        <p class="text-white/50 text-lg leading-relaxed">
          Whether you're an indie filmmaker or a network producer, the AI landscape is confusing and
          changing fast. We cut through the noise so you don't have to.
        </p>
      </div>

      <!-- Right: creator tags -->
      <div class="flex flex-wrap gap-3">
        {
          creators.map((c) => (
            <span class="bg-white/[0.05] border border-white/10 text-white/70 text-sm font-medium px-4 py-2 rounded-full">
              {c}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
